  "code": "var ctx=drawingContext,w=dimensionContext.width,h=dimensionContext.height,p=(state&&state.pfp)||{};function hs(hh,s,l,a){return 'hsla('+(((hh%360)+360)%360)+','+s+'%,'+l+'%,'+a+')';}var cx=w*(p.centerX||0.5),cy=h*(p.centerY||0.52),sc=(p.scale||1.0),fw=w*0.46*sc,fh=h*0.68*sc;var split=(p.split||0)*fw,gap=(p.eyeGap||0.2)*fw,brow=(p.brow||0.18)*fh,noseLen=(p.noseLen||0.22)*fh;ctx.save();ctx.translate(cx,cy);ctx.rotate((p.tilt||0)*0.12);var eyeLy=-fh*0.14,eyeRy=-fh*0.02;ctx.beginPath();ctx.moveTo(-gap-brow*0.05,eyeLy);ctx.bezierCurveTo(-gap+fw*0.06,eyeLy-fh*0.06,-gap+fw*0.11,eyeLy+fh*0.05,-gap-brow*0.04,eyeLy+fh*0.06);ctx.bezierCurveTo(-gap-fw*0.10,eyeLy+fh*0.06,-gap-fw*0.10,eyeLy-fh*0.05,-gap-brow*0.05,eyeLy);ctx.closePath();ctx.fillStyle='rgba(248,246,238,0.95)';ctx.fill();ctx.beginPath();ctx.arc(-gap*0.98,eyeLy+fh*0.01,w*0.014,0,Math.PI*2);ctx.fillStyle='rgba(14,14,20,0.95)';ctx.fill();ctx.beginPath();ctx.moveTo(split+fw*0.02,eyeRy);ctx.bezierCurveTo(split+fw*0.15,eyeRy-fh*0.05,split+fw*0.24,eyeRy+fh*0.04,split+fw*0.10,eyeRy+fh*0.06);ctx.bezierCurveTo(split-fw*0.02,eyeRy+fh*0.05,split-fw*0.02,eyeRy-fh*0.04,split+fw*0.02,eyeRy);ctx.closePath();ctx.fillStyle='rgba(248,246,238,0.93)';ctx.fill();ctx.beginPath();ctx.arc(split+fw*0.08,eyeRy+fh*0.01,w*0.012,0,Math.PI*2);ctx.fillStyle='rgba(16,16,22,0.95)';ctx.fill();ctx.beginPath();ctx.moveTo(-fw*0.02,-fh*0.12);ctx.bezierCurveTo(fw*0.06,-fh*0.02,fw*0.18,fh*0.04,fw*0.02,noseLen*0.7);ctx.bezierCurveTo(-fw*0.10,noseLen*0.58,-fw*0.09,fh*0.06,-fw*0.02,-fh*0.12);ctx.closePath();ctx.fillStyle=hs((p.h2||210)+24,58,44,0.95);ctx.fill();var mouthY=fh*(p.mouthCurve>0?0.30:0.26);ctx.beginPath();ctx.moveTo(-fw*0.20,mouthY);ctx.bezierCurveTo(-fw*0.02,mouthY+fh*(0.10+p.mouthCurve*0.12),fw*0.12,mouthY+fh*(0.08+p.mouthCurve*0.10),fw*0.24,mouthY);ctx.strokeStyle=hs((p.h4||20)+140,82,20,0.96);ctx.lineWidth=Math.max(2,w*0.010);ctx.stroke();ctx.restore();"
