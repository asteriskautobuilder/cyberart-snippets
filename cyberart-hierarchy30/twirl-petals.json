{
  "id": "glade-twirl-petals",
  "name": "Glade Twirl Petals",
  "description": "Move petals on torus",
  "phase": "update",
  "code": "var a=state.petals||[],w=dimensionContext.width,h=dimensionContext.height,t=state.t||0;for(var i=0;i<a.length;i++){var p=a[i];p.x+=p.vx+Math.sin(t*0.01+p.rot)*0.15;p.y+=p.vy+Math.cos(t*0.01+p.rot)*0.15;p.rot+=p.vr; if(p.x<0)p.x+=w;if(p.x>w)p.x-=w;if(p.y<0)p.y+=h;if(p.y>h)p.y-=h;}return state;"
}