  "phase": "getDefaultState",
  "code": "var n = 30 + R.int(20);\nvar ff = [];\nfor (var i = 0; i < n; i++) {\n  ff.push({\n    x: R.dec() * dimensionContext.width,\n    y: R.dec() * dimensionContext.height,\n    vx: (R.dec() - 0.5) * 0.4,\n    vy: (R.dec() - 0.5) * 0.3,\n    phase: R.dec() * Math.PI * 2,\n    glowSpeed: 0.015 + R.dec() * 0.025,\n    baseSize: 2 + R.dec() * 3,\n    hue: 40 + R.dec() * 40,\n    brightness: 0\n  });\n}\nvar ns = 80 + R.int(70);\nvar stars = [];\nfor (var i = 0; i < ns; i++) {\n  stars.push({\n    x: R.dec() * dimensionContext.width,\n    y: R.dec() * dimensionContext.height * 0.8,\n    size: 0.3 + R.dec() * 1.2,\n    twinkleSpeed: 0.01 + R.dec() * 0.03,\n    twinklePhase: R.dec() * Math.PI * 2\n  });\n}\nreturn Object.assign({}, state, { fireflies: ff, stars: stars });",
